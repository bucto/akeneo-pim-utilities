# --- Docker ---
APP_PORT=8085

# --- Zentrale MariaDB (externes Docker-Netzwerk) ---
DB_HOST=amada-db-mariadb11
DB_PORT=3306
DB_NETWORK=amada-db-network
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- Akeneo PIM API ---
# Vollständiger REST-Pfad, z.B. https://192.168.5.4/api/rest/v1
PIM_API_BASE_URL=https://192.168.5.4/api/rest/v1
PIM_API_USERNAME=
PIM_API_PASSWORD=
PIM_CLIENT_ID=
PIM_CLIENT_SECRET=
# true = selbstsigniertes Zertifikat ignorieren (internes PIM)
PIM_TLS_INSECURE=true

# --- Produktbilder ---
# Öffentliche URL unter der Akeneo-Medien abrufbar sind
PIM_MEDIA_BASE_URL=https://pim.amada.de
# Cache-Ordner für Thumbnails (thumbnail_small, thumbnail, preview, ...)
PIM_MEDIA_CACHE=thumbnail_small
# Kommagetrennte Bild-Attribute im PIM
PIM_IMAGE_ATTRS=picture,filename_picture_perspective
PIM_LOCALE=de_DE
PIM_CHANNEL=ecommerce
PIM_ARTICLE_NAME_ATTR=artikelname
# Ausstattungs-Vergleich: Assoziationstypen (z. B. included_components), leer = alle
PIM_ASSOC_VERBINDUNG_TYPES=included_components
# Technik-Vergleich: auszublendende Attribut-Codes
PIM_COMPARE_EXCLUDE_ATTRS=filename_picture_front,offer_id
PIM_BUILD_YEAR_ATTR=build_year
PIM_BUILT_UNTIL_ATTR=was_built_until
PIM_SERIES_FAMILY=series

# Abkantwerkzeug-Attribute (Fallback-Kette, kommagetrennt)
PIM_BENDING_HEIGHT_ATTRS=tool_height
PIM_BENDING_RADIUS_ATTRS=bendingtool_die_1v_shoulder_radius,bendingtool_die_2v_shoulder_radius
PIM_BENDING_SERIES_ATTRS=series_name
PIM_BENDING_LENGTH_ATTRS=tool_length
PIM_BENDING_SAP_ATTRS=sap_nummer

# Werkzeugfinder: optional kommagetrennte Familien (leer = Admin/DB oder bendingtool_*)
# PIM_BENDING_FAMILIES=bendingtool_die_4v
PIM_BENDING_SIZE_ATTRS=bendingtool_die_1v_size,bendingtool_die_4v_size
PIM_BENDING_ANGLE_ATTRS=bendingtool_die_1v_angle,bendingtool_die_4v_angle
# Serie-Filter (z. B. afh) — leer = alle Serien
PIM_BENDING_SERIES_FILTER=afh

# Admin-Bereich (PIM-Familien konfigurieren) – nur true für Admins setzen
ADMIN_ENABLED=false

# Optionale Schnellauswahl im Produkt-Vergleich: app/data/compare_presets.json
# (Vorlage: app/data/compare_presets.example.json)

# Footer
APP_AUTHOR=Thomas Bücken
APP_REPO=https://github.com/bucto/akeneo-pim-utilities
APP_GIT_BRANCH=main
# Optional bei GitHub Rate-Limits (public repo meist nicht noetig):
GITHUB_TOKEN=
# Manuelles Override (optional):
# APP_REVISION=
