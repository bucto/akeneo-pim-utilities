# --- Docker ---
APP_PORT=8085

# --- Zentrale MariaDB (externes Docker-Netzwerk) ---
DB_HOST=amada-db-mariadb11
DB_PORT=3306
DB_NETWORK=amada-db-network
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- Akeneo PIM API ---
# Vollständiger REST-Pfad, z.B. https://192.168.5.4/api/rest/v1
PIM_API_BASE_URL=https://192.168.5.4/api/rest/v1
PIM_API_USERNAME=
PIM_API_PASSWORD=
PIM_CLIENT_ID=
PIM_CLIENT_SECRET=
# true = selbstsigniertes Zertifikat ignorieren (internes PIM)
PIM_TLS_INSECURE=true

# --- Produktbilder ---
# Öffentliche URL unter der Akeneo-Medien abrufbar sind
PIM_MEDIA_BASE_URL=https://pim.amada.de
# Cache-Ordner für Thumbnails (thumbnail_small, thumbnail, preview, ...)
PIM_MEDIA_CACHE=thumbnail_small
# Kommagetrennte Bild-Attribute im PIM
PIM_IMAGE_ATTRS=picture,filename_picture_perspective
PIM_LOCALE=de_DE
PIM_CHANNEL=ecommerce

# Abkantwerkzeug-Attribute (Fallback-Kette, kommagetrennt)
PIM_BENDING_HEIGHT_ATTRS=bendingtool_tool_height,bendingtool_die_height,bendingtool_height
PIM_BENDING_RADIUS_ATTRS=bendingtool_die_radius,bendingtool_radius,bendingtool_die_1v_radius
PIM_BENDING_SERIES_ATTRS=series,bendingtool_series
PIM_BENDING_LENGTH_ATTRS=bendingtool_tool_length,bendingtool_length,bendingtool_die_length

# Admin-Bereich (PIM-Familien konfigurieren) – nur true für Admins setzen
ADMIN_ENABLED=false

# Footer
APP_AUTHOR=Thomas Bücken
APP_REPO=https://github.com/bucto/akeneo-pim-utilities
APP_GIT_BRANCH=main
# Privates GitHub-Repo: Read-only PAT (repo:read oder public_repo)
# Ohne Token wird ein Quellcode-Hash (src-abc1234) angezeigt statt Git-Commit.
GITHUB_TOKEN=
# Manuelles Override (optional):
# APP_REVISION=
